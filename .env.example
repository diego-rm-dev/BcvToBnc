# Database
DATABASE_URL="file:./dev.db"

# App
APP_BASE_URL="http://localhost:3000"
ALLOWED_ORIGINS="http://localhost:3000"

# On-ramp defaults
ONRAMP_PROVIDER="transak"
DEFAULT_WALLET_ADDRESS="0xYOUR_WALLET_ADDRESS"
DEFAULT_NETWORK="ethereum"
DEFAULT_CRYPTO_CURRENCY="USDT"
DEFAULT_FIAT_CURRENCY="USD"

# Transak placeholders
TRANSAK_API_KEY=""
TRANSAK_PARTNER_ACCESS_TOKEN=""
# Optional: token específico para verificar/decodificar JWT de webhooks.
TRANSAK_WEBHOOK_ACCESS_TOKEN=""
TRANSAK_REFERRER_DOMAIN="localhost:3000"
TRANSAK_ENVIRONMENT="STAGING"
TRANSAK_WEBHOOK_SECRET=""
# Optional: backend endpoint para crear sesión server-to-server con Transak.
TRANSAK_SESSIONS_API_URL="https://api-gateway-stg.transak.com/api/v2/auth/session"
# Optional: endpoint de cotización backend.
TRANSAK_QUOTES_API_URL=""
# Optional: método de pago por defecto en widget.
TRANSAK_DEFAULT_PAYMENT_METHOD=""
# Optional: configuración de validación de firma webhook.
TRANSAK_WEBHOOK_SIGNATURE_HEADER="x-webhook-signature"
TRANSAK_WEBHOOK_SIGNATURE_ALGO="sha256"

# Basic rate limit for POST /api/session/create
SESSION_CREATE_RATE_LIMIT_WINDOW_MS="60000"
SESSION_CREATE_RATE_LIMIT_MAX_REQUESTS="20"
